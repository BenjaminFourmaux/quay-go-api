    },
    "paths": {
        "/api/v1/users/me": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Get the current authenticated user information",
                "tags": [
                    "Users"
                ],
                "summary": "Get the current authenticated user information",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/Models.User"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/Errors.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Get the API health status",
                "tags": [
                    "Health"
                ],
                "summary": "Get the API health status",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "Errors.ErrorDetails": {
            "type": "object",
            "properties": {
                "code": {
                    "description": "Code is a sting that represents the error code (e.g. \"USER_NOT_FOUND\", \"INVALID_INPUT\", etc.)",
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "Errors.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "$ref": "#/definitions/Errors.ErrorDetails"
                }
            }
        },
        "Models.User": {
            "type": "object"
        }
    },
    "securityDefinitions": {
